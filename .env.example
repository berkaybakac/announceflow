# AnnounceFlow optional environment overrides
# Copy to .env and edit only if needed.
# App works without .env; missing secret key is auto-generated and persisted.

# Session security key (optional; if omitted app auto-generates on first run)
# FLASK_SECRET_KEY=CHANGE_ME_WITH_LONG_RANDOM_SECRET

# Optional runtime overrides
# ANNOUNCEFLOW_WEB_PORT=5001
# ANNOUNCEFLOW_MEDIA_FOLDER=media
# ANNOUNCEFLOW_SCHEDULER_INTERVAL_SECONDS=10

# Optional admin overrides
# ANNOUNCEFLOW_ADMIN_USERNAME=admin
# ANNOUNCEFLOW_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Optional deploy overrides (for deploy.sh)
# PI_USER=admin
# PI_HOST=aflow.local
